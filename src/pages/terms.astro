---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css'
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Terms and Conditions | Sergio Ramírez Morón</title>
</head>
<body class="bg-white text-gray-900 font-sans antialiased">
    
    <Header />

    <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl mb-8">
            Terms and Conditions
        </h1>

        <div class="space-y-6 text-gray-600 leading-relaxed">
            <p>
                By accessing this website, you agree to be bound by these terms of service, all applicable laws and regulations, and you agree that you are responsible for compliance with any applicable local laws.
            </p>

            <section>
                <h2 class="text-xl font-semibold text-gray-900 mb-3">1. License Use</h2>
                <p>
                    The content of this portfolio (code, images, text) is my intellectual property unless otherwise stated.
                </p>
                <ul class="list-disc pl-5 mt-2 space-y-1">
                    <li>You may view and share the content for personal and non-commercial use.</li>
                    <li>You may not modify or copy the material to use it as your own without attribution.</li>
                </ul>
            </section>

            <section>
                <h2 class="text-xl font-semibold text-gray-900 mb-3">2. Limitations</h2>
                <p>
                    In no event shall I be liable for any damages (including, without limitation, damages for loss of data or profit) arising out of the use or inability to use the materials on this website.
                </p>
            </section>
        </div>
    </main>

    <Footer />
</body>
</html>
