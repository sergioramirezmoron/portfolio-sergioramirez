---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const projects = [
  {
    title: "Social Media Platform",
    description: "A minimalist social network application. Features include user authentication, post creation with images, likes, and comments, user search and profile management.",
    tags: ["PHP", "Symfony", "CSS", "MySQL"],
    // NOTA: En Astro, si la imagen está en /public/img, la ruta es /img/...
    image: "/img/proyecto_red_social.png" 
  },
  {
    title: "Employee Management System",
    description: "A CRUD application for managing staff records. Features a registration form integrated with a dynamic table to display and organize employee data.",
    tags: ["React", "Express", "Axios", "MySQL"],
    image: "/img/proyecto_gestion_empleados.png"
  },
  {
    title: "Ruby Expansion Mod (Fabric)",
    description: "A Minecraft 1.21.1 mod developed in Java using the Fabric API. Features custom entities (RubiCritter), a new toolset, and a custom block.",
    tags: ["Java", "Fabric API", "Game Modding"],
    image: "/img/proyecto_minecraft_rubi.png"
  }
];

const skills = [
  "HTML/CSS", "Tailwind CSS", "JavaScript", "React", "TypeScript", 
  "PHP", "Symfony", "Java", "Spring Boot", "Node.js", 
  "Express", "Astro", "Python", "MySQL", "PostgreSQL", 
  "SQLite", "Git", "Docker", "Podman", "Artificial Intelligence"
];
---

<Layout>
    <Header />

    <main>
        <section id="home" class="min-h-screen flex items-center justify-center pt-32 pb-12 px-4 sm:px-6 lg:px-8 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-50 via-white to-white">
            <div class="text-center max-w-4xl mx-auto">
                <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-gray-900 mb-6">
                    Sergio Ramírez Morón<br />
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">
                        Full Stack Developer
                    </span>
                </h1>
                <p class="mt-4 text-xl text-gray-600 max-w-2xl mx-auto mb-10 leading-relaxed">
                    Young and passionate technologist with a strong interest in Web Development and Artificial Intelligence. I turn complex problems into efficient digital solutions.
                </p>
                <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <a href="#projects" class="px-8 py-3 text-base font-semibold text-white bg-blue-600 rounded-full hover:bg-blue-700 transition-all shadow-lg hover:shadow-blue-500/30 hover:-translate-y-1">
                        Check my work
                    </a>
                    <a href="#contact" class="px-8 py-3 text-base font-semibold text-gray-700 bg-white border border-gray-200 rounded-full hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm">
                        Contact me
                    </a>
                </div>
            </div>
        </section>

        <section id="about" class="py-24 bg-white border-b border-gray-100">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
                    <div class="order-2 lg:order-1">
                        <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl mb-6">About Me</h2>
                        <div class="space-y-4 text-lg text-gray-600 leading-relaxed">
                            <p>
                                Hi! I'm Sergio. I define myself as a developer with a mindset geared towards <strong class="text-blue-600">continuous learning</strong> and constant improvement.
                            </p>
                            <p>
                                My journey started with curiosity about how things work on the internet, and today I focus on building functional, scalable, and visually appealing web applications. I am also deeply interested in the intersection of web tech and <strong class="text-blue-600">Artificial Intelligence</strong>.
                            </p>
                        </div>
                        
                        <div class="mt-8">
                            <h3 class="font-bold text-gray-900 mb-4 text-sm uppercase tracking-wider">Tech Stack & Tools</h3>
                            <div class="flex flex-wrap gap-2">
                                {skills.map((skill) => (
                                    <span class="px-3 py-1.5 rounded-lg bg-gray-50 text-gray-700 text-sm font-medium border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-colors cursor-default">
                                        {skill}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-10 lg:mt-0 relative order-1 lg:order-2">
                        <div class="absolute -inset-4 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl opacity-20 blur-xl"></div>
                        <img 
                            src="https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
                            alt="Sergio working on code" 
                            class="relative rounded-2xl shadow-2xl border border-gray-100 grayscale hover:grayscale-0 transition-all duration-500 transform hover:scale-[1.02]"
                        />
                    </div>
                </div>
            </div>
        </section>

        <section id="projects" class="py-24 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">Featured Projects</h2>
                    <p class="mt-4 text-gray-500 max-w-2xl mx-auto">A selection of my recent work, ranging from web applications to game modifications.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {projects.map((project) => (
                        <article class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col group hover:-translate-y-1">
                            <div class="h-48 overflow-hidden bg-gray-100 relative border-b border-gray-100">
                                <div class="absolute inset-0 bg-blue-900/0 group-hover:bg-blue-900/5 transition-colors z-10"></div>
                                <img 
                                    src={project.image} 
                                    alt={project.title} 
                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                    onerror="this.onerror=null; this.src='https://via.placeholder.com/600x400?text=Project+Image'" 
                                />
                            </div>
                            <div class="p-6 flex-1 flex flex-col">
                                <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">{project.title}</h3>
                                <p class="text-gray-600 text-sm mb-4 flex-1 leading-relaxed">{project.description}</p>
                                <div class="flex flex-wrap gap-2 mt-auto pt-4 border-t border-gray-50">
                                    {project.tags.map((tag) => (
                                        <span class="text-[10px] uppercase tracking-wide font-bold text-blue-700 bg-blue-50 px-2 py-1 rounded-md">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
                
                <div class="text-center mt-12">
                    <a href="https://github.com/sergioramirezmoron" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 font-medium transition-colors border-b border-transparent hover:border-gray-900 pb-0.5">
                        View more on GitHub
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>
        </section>

        <section id="contact" class="py-24 bg-white relative overflow-hidden">
            <div class="max-w-3xl mx-auto px-4 text-center relative z-10">
                <h2 class="text-3xl font-bold text-gray-900 mb-6">Ready to start a project?</h2>
                <p class="text-xl text-gray-500 mb-10">
                    I am currently open to new opportunities. Whether you have a question or just want to say hi, I'll try my best to get back to you!
                </p>
                
                <div class="flex flex-col sm:flex-row justify-center gap-4 mb-12">
                    <a href="https://mail.google.com/mail/?view=cm&fs=1&to=sergioramirezmoron@gmail.com" target="_blank" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-gray-900 rounded-full hover:bg-gray-800 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1">
                        Send via Gmail
                        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </a>
                    
                    <a href="https://www.linkedin.com/in/sergio-ramírez-morón-550648357/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-blue-700 bg-blue-50 rounded-full hover:bg-blue-100 transition-colors border border-blue-200">
                        LinkedIn Profile
                    </a>
                </div>

                <div class="p-6 bg-gray-50 rounded-2xl border border-gray-100 inline-block">
                    <p class="text-gray-500 text-sm mb-2">Or email me directly at:</p>
                    <p class="text-lg font-mono font-bold text-gray-900 select-all">sergioramirezmoron@gmail.com</p>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>