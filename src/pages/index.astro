---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const projects = [
    {
    title: "GasoFlow",
    description: "Real-time fuel price tracker and route optimizer. Helps drivers find the cheapest nearby stations and plan cost-efficient trips.",
    tags: ["React"],
    image: "/img/proyecto_gasoflow.png",
    number: "04",
    accent: "#f59e0b"
  },
  {
    title: "Social Media Platform",
    description: "A minimalist social network with user authentication, post creation with images, likes, comments, and full profile management.",
    tags: ["PHP", "Symfony", "CSS", "MySQL"],
    image: "/img/proyecto_red_social.png",
    number: "01",
    accent: "#3b82f6"
  },
  {
    title: "Personal Wallet",
    description: "Automated personal finance workflow built on n8n. Tracks expenses, generates smart monthly summaries, and sends digest reports automatically.",
    tags: ["n8n", "Automation", "Google Sheets", "Telegram Bot"],
    image: "/img/proyecto_personal_wallet.png",
    number: "06",
    accent: "#8b5cf6"
  },
    {
    title: "JobFinder",
    description: "An intelligent job offer aggregator that filters out scams using heuristic analysis. Only surfaces legitimate, quality opportunities.",
    tags: ["n8n", "Automation", "Telegram Bot"],
    image: "/img/proyecto_jobfinder.png",
    number: "07",
    accent: "#14b8a6"
  },
    {
    title: "GeoSismo",
    description: "Live seismic monitoring dashboard. Visualizes earthquake activity with interactive maps, magnitude filters, and alert notifications.",
    tags: ["React"],
    image: "/img/proyecto_geosismo.png",
    number: "05",
    accent: "#10b981"
  },
  {
    title: "Employee Management System",
    description: "A CRUD application for managing staff records. Features a registration form integrated with a dynamic table for organized employee data.",
    tags: ["React", "Express", "Axios", "MySQL"],
    image: "/img/proyecto_gestion_empleados.png",
    number: "02",
    accent: "#6366f1"
  },
  {
    title: "Ruby Expansion Mod",
    description: "A Minecraft 1.21.1 mod built in Java with Fabric API. Custom entities (RubiCritter), new toolsets, and a handcrafted block system.",
    tags: ["Java", "Fabric API", "Game Modding"],
    image: "/img/proyecto_minecraft_rubi.png",
    number: "03",
    accent: "#ec4899"
  },
];

const skills = [
  "HTML/CSS", "Tailwind CSS", "JavaScript", "React", "Angular", "TypeScript",
  "PHP", "Symfony", "Java", "Spring Boot", "Node.js",
  "Astro", "Python", "SQL",
  "Git", "Docker", "Podman", "Artificial Intelligence"
];
---

<Layout>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

    :root {
      --ink: #0a0a0f;
      --paper: #f5f4f0;
      --blue: #2563eb;
      --blue-light: #dbeafe;
      --muted: #6b7280;
      --border: #e5e4df;
      --card-bg: #ffffff;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--paper);
      color: var(--ink);
      overflow-x: hidden;
    }

    /* ── NOISE TEXTURE OVERLAY ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.6;
    }

    /* ── TYPOGRAPHY ── */
    h1, h2, h3, h4 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--paper); }
    ::-webkit-scrollbar-thumb { background: #c4c3bd; border-radius: 3px; }

    /* ── HERO ── */
    .hero {
      min-height: 100svh;
      display: grid;
      grid-template-rows: 1fr auto;
      padding: 7rem 2rem 3rem;
      position: relative;
      overflow: hidden;
    }

    .hero-bg-number {
      position: absolute;
      top: 50%;
      right: -4rem;
      transform: translateY(-50%);
      font-family: 'Syne', sans-serif;
      font-size: clamp(8rem, 35vw, 38rem);
      font-weight: 800;
      color: transparent;
      -webkit-text-stroke: 1px #e0dfd9;
      line-height: 1;
      pointer-events: none;
      user-select: none;
      letter-spacing: -0.05em;
    }

    .hero-inner {
      max-width: 1280px;
      margin: 0 auto;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2.5rem;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--muted);
    }

    .hero-title {
      font-size: clamp(2.8rem, 8vw, 8rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      max-width: 900px;
    }

    .hero-title em {
      font-style: normal;
      color: var(--blue);
      position: relative;
    }

    .hero-title em::after {
      content: '';
      position: absolute;
      bottom: 0.08em;
      left: 0;
      width: 100%;
      height: 0.06em;
      background: var(--blue);
      opacity: 0.3;
      border-radius: 2px;
    }

    .hero-desc {
      font-size: 1.1rem;
      line-height: 1.7;
      color: var(--muted);
      max-width: 480px;
      font-weight: 300;
    }

    .hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 2rem;
      background: var(--ink);
      color: var(--paper);
      font-family: 'Syne', sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      border-radius: 3px;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .btn-primary:hover {
      background: var(--blue);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(37,99,235,0.25);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 2rem;
      background: transparent;
      color: var(--ink);
      font-family: 'Syne', sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      border: 1.5px solid var(--border);
      border-radius: 3px;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .btn-secondary:hover {
      border-color: var(--ink);
      background: var(--ink);
      color: var(--paper);
    }

    .hero-scroll-hint {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      padding-bottom: 1rem;
    }

    .scroll-line {
      width: 2.5rem;
      height: 1px;
      background: var(--muted);
      animation: scrollPulse 2s ease-in-out infinite;
    }

    @keyframes scrollPulse {
      0%, 100% { opacity: 0.3; transform: scaleX(1); }
      50% { opacity: 1; transform: scaleX(1.3); transform-origin: left; }
    }

    /* ── MARQUEE ── */
    .marquee-wrapper {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 0.9rem 0;
      overflow: hidden;
      background: var(--ink);
    }

    .marquee-track {
      display: flex;
      gap: 0;
      width: max-content;
      animation: marquee 28s linear infinite;
    }

    .marquee-item {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 0 2rem;
      white-space: nowrap;
      font-family: 'Syne', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(245,244,240,0.35);
    }

    .marquee-item span {
      color: var(--blue);
      font-size: 1rem;
      line-height: 1;
    }

    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ── SECTION WRAPPER ── */
    .section {
      padding: 7rem 2rem;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      width: 100%;
    }

    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 1.5rem;
    }

    .section-label::before {
      content: '';
      display: block;
      width: 1.5rem;
      height: 1.5px;
      background: var(--blue);
    }

    /* ── ABOUT ── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 4rem;
      align-items: center;
    }

    @media (min-width: 1024px) {
      .about-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .about-heading {
      font-size: clamp(2rem, 5vw, 4.5rem);
      line-height: 1;
      margin-bottom: 2rem;
    }

    .about-heading .line2 {
      color: var(--muted);
      font-weight: 400;
    }

    .about-text {
      font-size: 1rem;
      line-height: 1.8;
      color: #4b5563;
      font-weight: 300;
    }

    .about-text + .about-text {
      margin-top: 1rem;
    }

    .about-text strong {
      color: var(--ink);
      font-weight: 500;
    }

    .skills-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1rem;
      margin-top: 2.5rem;
    }

    .skills-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .skill-tag {
      padding: 0.4rem 0.85rem;
      background: var(--paper);
      border: 1px solid var(--border);
      font-size: 0.78rem;
      font-weight: 500;
      color: #374151;
      border-radius: 2px;
      transition: all 0.15s ease;
      cursor: default;
    }

    .skill-tag:hover {
      border-color: var(--blue);
      color: var(--blue);
      background: var(--blue-light);
    }

    /* ── ABOUT IMAGE ── */
    .about-img-wrap {
      position: relative;
    }

    .about-img-frame {
      position: relative;
      border-radius: 4px;
      overflow: hidden;
      aspect-ratio: 4/5;
    }

    /* On mobile, reduce the heavy aspect ratio so image isn't huge */
    @media (max-width: 1023px) {
      .about-img-frame {
        aspect-ratio: 16/9;
        max-height: 340px;
      }
    }

    .about-img-frame::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(37,99,235,0.08) 0%, transparent 60%);
      z-index: 1;
      pointer-events: none;
    }

    .about-img-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(0.2) contrast(1.05);
      transition: filter 0.5s ease;
    }

    .about-img-frame:hover img {
      filter: grayscale(0) contrast(1);
    }

    .about-img-deco {
      position: absolute;
      bottom: -1.5rem;
      right: -1.5rem;
      width: 7rem;
      height: 7rem;
      border: 2px solid var(--blue);
      border-radius: 4px;
      opacity: 0.25;
    }

    .about-img-deco2 {
      position: absolute;
      top: -1.5rem;
      left: -1.5rem;
      width: 4rem;
      height: 4rem;
      background: var(--blue);
      border-radius: 4px;
      opacity: 0.08;
    }

    /* ── PROJECTS ── */
    .projects-section {
      background: var(--ink);
      padding: 7rem 2rem;
    }

    .projects-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 4rem;
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .projects-heading {
      font-size: clamp(2rem, 5vw, 4.5rem);
      color: var(--paper);
      line-height: 1;
    }

    .projects-heading .muted {
      color: #4b5563;
    }

    .projects-github-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #6b7280;
      text-decoration: none;
      transition: color 0.2s;
    }

    .projects-github-link:hover { color: var(--paper); }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(1, 1fr);
      gap: 1px;
      background: #1f2937;
      border: 1px solid #1f2937;
      border-radius: 6px;
      overflow: hidden;
    }

    @media (min-width: 640px) {
      .projects-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (min-width: 1024px) {
      .projects-grid { grid-template-columns: repeat(3, 1fr); }
    }

    .project-card {
      background: #0d1117;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      position: relative;
      overflow: hidden;
      transition: background 0.3s ease;
      cursor: default;
    }

    /* Tighter padding on small screens */
    @media (max-width: 479px) {
      .project-card {
        padding: 1.5rem 1.25rem;
      }
    }

    .project-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent, var(--blue));
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .project-card:hover {
      background: #111827;
    }

    .project-card:hover::before {
      opacity: 1;
    }

    .project-num {
      font-family: 'Syne', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: #374151;
    }

    .project-img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      border-radius: 3px;
      filter: grayscale(0.4) brightness(0.85);
      transition: all 0.4s ease;
      background: #1a1f2e;
    }

    .project-card:hover .project-img {
      filter: grayscale(0) brightness(1);
      transform: scale(1.02);
    }

    .project-title {
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--paper);
      line-height: 1.2;
    }

    .project-desc {
      font-size: 0.85rem;
      line-height: 1.65;
      color: #6b7280;
      font-weight: 300;
      flex: 1;
    }

    .project-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      padding-top: 0.75rem;
      border-top: 1px solid #1f2937;
    }

    .project-tag {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.25rem 0.6rem;
      border-radius: 2px;
      background: #1a1f2e;
      color: #9ca3af;
      border: 1px solid #1f2937;
    }

    /* ── CONTACT ── */
    .contact-section {
      padding: 8rem 2rem;
      background: var(--paper);
    }

    .contact-inner {
      max-width: 800px;
      margin: 0 auto;
    }

    .contact-heading {
      font-size: clamp(2.5rem, 7vw, 6.5rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      margin-bottom: 2rem;
    }

    .contact-heading .line2 {
      color: var(--blue);
    }

    .contact-sub {
      font-size: 1.1rem;
      color: var(--muted);
      font-weight: 300;
      line-height: 1.7;
      max-width: 500px;
      margin-bottom: 3rem;
    }

    .contact-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 3.5rem;
    }

    /* Full-width buttons on very small screens */
    @media (max-width: 400px) {
      .contact-actions {
        flex-direction: column;
      }
      .contact-actions .btn-primary,
      .contact-actions .btn-secondary {
        width: 100%;
        justify-content: center;
      }
    }

    .contact-email-block {
      display: inline-block;
      padding: 1.25rem 2rem;
      background: #f9f8f4;
      border: 1px solid var(--border);
      border-radius: 3px;
      /* Prevent overflow on tiny screens */
      max-width: 100%;
      word-break: break-all;
    }

    .contact-email-block p:first-child {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.35rem;
    }

    .contact-email-block p:last-child {
      font-family: 'Syne', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink);
      user-select: all;
    }

    /* ── FADE-IN ANIMATIONS ── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
      .hero {
        padding: 6rem 1.25rem 2.5rem;
        /* Ensure scroll hint is visible */
        min-height: 100svh;
      }

      .hero-inner {
        gap: 1.75rem;
      }

      .hero-desc {
        font-size: 1rem;
      }

      .section {
        padding: 5rem 1.25rem;
      }

      .projects-section {
        padding: 5rem 1.25rem;
      }

      .projects-header {
        margin-bottom: 2.5rem;
      }

      .contact-section {
        padding: 5rem 1.25rem;
      }

      .contact-sub {
        font-size: 1rem;
      }

      .about-img-deco,
      .about-img-deco2 {
        display: none;
      }

      .projects-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    /* ── TABLET (641px – 1023px) ── */
    @media (min-width: 641px) and (max-width: 1023px) {
      .hero {
        padding: 6.5rem 2.5rem 3rem;
      }

      .section {
        padding: 6rem 2.5rem;
      }

      .projects-section {
        padding: 6rem 2.5rem;
      }

      .contact-section {
        padding: 6rem 2.5rem;
      }

      /* Image takes reasonable space before two-col layout kicks in */
      .about-img-frame {
        max-height: 420px;
      }

      .about-img-deco,
      .about-img-deco2 {
        display: none;
      }
    }

    /* ── EXTRA SMALL (< 400px) ── */
    @media (max-width: 400px) {
      .hero {
        padding: 5.5rem 1rem 2rem;
      }

      .hero-title {
        font-size: clamp(2.4rem, 12vw, 3rem);
      }

      .hero-desc {
        font-size: 0.95rem;
      }

      .btn-primary,
      .btn-secondary {
        padding: 0.75rem 1.5rem;
        font-size: 0.82rem;
      }

      .section {
        padding: 4rem 1rem;
      }

      .projects-section {
        padding: 4rem 1rem;
      }

      .contact-section {
        padding: 4rem 1rem;
      }

      .contact-email-block {
        padding: 1rem 1.25rem;
      }

      .contact-email-block p:last-child {
        font-size: 0.85rem;
      }
    }
  </style>

  <Header />

  <main>
    <!-- ── HERO ── -->
    <section id="home" class="hero">
      <div class="hero-bg-number" aria-hidden="true">SR</div>

      <div class="hero-inner">
        <div class="reveal">
          <p class="hero-eyebrow">Available for new projects</p>
        </div>

        <h1 class="hero-title reveal reveal-delay-1">
          Sergio<br />
          Ramírez<br />
          <em>Morón</em>
        </h1>

        <p class="hero-desc reveal reveal-delay-2">
          Full Stack Developer & AI enthusiast. I turn complex problems into clean, efficient digital solutions.
        </p>

        <div class="hero-ctas reveal reveal-delay-3">
          <a href="#projects" class="btn-primary">
            View projects
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#contact" class="btn-secondary">Get in touch</a>
        </div>
      </div>

      <div class="hero-scroll-hint reveal reveal-delay-4">
        <span class="scroll-line"></span>
        Scroll to explore
      </div>
    </section>

    <div class="marquee-wrapper" aria-hidden="true">
      <div class="marquee-track">
        {[...Array(2)].map(() => (
          skills.map((item) => (
            <div class="marquee-item">
              <span>·</span>
              {item}
            </div>
          ))
        ))}
      </div>
    </div>

    <!-- ── ABOUT ── -->
    <section id="about" class="section" style="background: var(--paper);">
      <div class="container">
        <p class="section-label reveal">About me</p>

