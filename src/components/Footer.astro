<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');

  .site-footer {
    background: #0a0a0f;
    border-top: 1px solid #1f2937;
    padding: 5rem 2rem 2.5rem;
    font-family: 'DM Sans', sans-serif;
  }

  .footer-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── TOP: brand + nav + social ── */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid #111827;
  }

  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 4rem;
    }
  }

  /* Brand col */
  .footer-brand {}

  .footer-logo {
    font-family: 'Syne', sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #f5f4f0;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    line-height: 1;
    transition: opacity 0.2s;
  }

  .footer-logo:hover { opacity: 0.6; }

  .footer-logo-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    background: #2563eb;
    border-radius: 50%;
    margin-left: 3px;
    margin-bottom: 2px;
    flex-shrink: 0;
  }

  .footer-tagline {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #374151;
    font-weight: 300;
    max-width: 280px;
  }

  /* Nav col */
  .footer-col-label {
    font-family: 'Syne', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #374151;
    margin-bottom: 1.25rem;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer-nav-link {
    font-size: 0.9rem;
    font-weight: 400;
    color: #6b7280;
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 1px solid #111827;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: color 0.2s ease;
  }

  .footer-nav-link:last-child { border-bottom: none; }

  .footer-nav-link svg {
    width: 10px;
    height: 10px;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .footer-nav-link:hover {
    color: #f5f4f0;
  }

  .footer-nav-link:hover svg {
    opacity: 1;
    transform: translateX(0);
  }

  /* Social col */
  .footer-social-links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid #111827;
    text-decoration: none;
    color: #6b7280;
    font-size: 0.85rem;
    font-weight: 400;
    transition: color 0.2s ease;
  }

  .footer-social-link:last-child { border-bottom: none; }

  .footer-social-link:hover { color: #f5f4f0; }

  .footer-social-link svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .footer-social-link:hover svg { opacity: 1; }

  /* ── BOTTOM ── */
  .footer-bottom {
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #374151;
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  .footer-copy span {
    color: #2563eb;
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer-legal a {
    font-size: 0.72rem;
    color: #374151;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer-legal a:hover { color: #6b7280; }

  @media (max-width: 640px) {
    .site-footer { padding: 4rem 1.25rem 2rem; }
  }
</style>

